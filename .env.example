APP_NAME="AssetFlow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://assetflow.example.local
COMPANY_NAME="Your Company"
ASSETFLOW_BRAND_COLOR="#1459D9"
ASSETFLOW_METRICS_CACHE_MINUTES=0
ASSETFLOW_DEFAULT_EMAIL_DOMAIN=example.local
ASSETFLOW_ADMIN_EMAIL=admin@example.local
ASSETFLOW_ADMIN_NAME="System Administrator"
ASSETFLOW_ADMIN_USERNAME=admin
# Leave empty unless you intentionally want env-driven defaults.
# First-run setup at /setup asks for admin password interactively.
ASSETFLOW_ADMIN_PASSWORD=
ASSETFLOW_IMPORT_DEFAULT_PASSWORD=
ASSETFLOW_DEMO_PASSWORD=
ASSETFLOW_DEFAULT_VENDOR_EMAIL=procurement@example.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=assetflow
DB_USERNAME=root
DB_PASSWORD=
DB_TIMEZONE=+00:00

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.example.local
MAIL_PORT=465
MAIL_USERNAME=noreply@example.local
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@example.local"
MAIL_FROM_NAME="${APP_NAME}"
ASSETFLOW_EMAIL_RECEIPTS=false
ASSETFLOW_EMAIL_RETURNS=true
ASSETFLOW_EMAIL_RECEIPTS_CC_ACTOR=true
ASSETFLOW_EMAIL_RECEIPTS_FALLBACK_TO_ACTOR=true
ASSETFLOW_EMAIL_RECEIPTS_BCC=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
